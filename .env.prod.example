# ============================================================================
# WorkTime - Production Environment Template
# ============================================================================
# Copy to .env.prod and fill in real values from your secret manager.
# DO NOT commit .env.prod. DO NOT share via chat/email.
#
# For documentation on every variable (defaults, formats, security notes),
# see .env.example. This file only captures the PRODUCTION DELTAS:
#   - host-internal service names for docker-compose.prod (postgres, redis)
#   - TLS-enforced connection strings (sslmode=require, rediss://)
#   - strong-secret placeholders: <set in secret manager>
#   - nginx + Let's Encrypt variables (prod-only)
#
# Recommended secret backends: AWS Secrets Manager, Hashicorp Vault,
# Doppler, 1Password Connect, or GitHub Actions secrets for CI deploys.
# ============================================================================


# ----------------------------------------------------------------------------
# Database (PostgreSQL) - managed or self-hosted
# ----------------------------------------------------------------------------
# Host MUST be the compose service name ("postgres") so the api container
# resolves via the docker network. If using a managed Postgres (RDS, Cloud
# SQL, Neon), point DATABASE_URL at its host and leave POSTGRES_* unused.
# Always append ?sslmode=require in production.
# ----------------------------------------------------------------------------
POSTGRES_DB=worktime
POSTGRES_USER=worktime
POSTGRES_PASSWORD=<set in secret manager>
DATABASE_URL=postgres://worktime:<set in secret manager>@postgres:5432/worktime?sslmode=require


# ----------------------------------------------------------------------------
# Redis (cache, queues, rate limits)
# ----------------------------------------------------------------------------
# Use rediss:// for TLS (Upstash, Redis Enterprise, ElastiCache with TLS).
# For the bundled redis container, keep redis:// but set REDIS_PASSWORD and
# uncomment `requirepass` in docker/redis/redis.conf.
# ----------------------------------------------------------------------------
REDIS_URL=rediss://:<set in secret manager>@redis:6379
REDIS_PASSWORD=<set in secret manager>


# ----------------------------------------------------------------------------
# Auth / JWT / Crypto - generate strong secrets
# ----------------------------------------------------------------------------
# Each must be at least 64 bytes of entropy. Suggested generator:
#   openssl rand -hex 64
# Rotate JWT_SECRET / JWT_REFRESH_SECRET during a maintenance window; all
# sessions will be invalidated. Rotating QR_HMAC_SECRET requires reprinting
# all office QR codes.
# ----------------------------------------------------------------------------
JWT_SECRET=<set in secret manager>
JWT_REFRESH_SECRET=<set in secret manager>
QR_HMAC_SECRET=<set in secret manager>
JWT_PUBLIC_SECRET=<set in secret manager>


# ----------------------------------------------------------------------------
# Telegram
# ----------------------------------------------------------------------------
# Use a DIFFERENT bot for production than for staging/dev to avoid update
# collisions. Register webhook via:
#   curl -F url=https://your-domain.kz/api/telegram/webhook \
#        -F secret_token=$TELEGRAM_WEBHOOK_SECRET \
#        https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/setWebhook
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=<set in secret manager>
TELEGRAM_BOT_USERNAME=worktime_bot
SUPER_ADMIN_TELEGRAM_IDS=<comma-separated bigints>
TELEGRAM_WEBHOOK_SECRET=<set in secret manager>


# ----------------------------------------------------------------------------
# API / HTTP
# ----------------------------------------------------------------------------
# Behind nginx, API_PORT is an internal port (not exposed to the public).
# WEB_URL is the public HTTPS origin; CORS is derived from it.
# ----------------------------------------------------------------------------
API_PORT=4000
WEB_URL=https://your-domain.kz


# ----------------------------------------------------------------------------
# Frontend (NEXT_PUBLIC_*) - baked at `next build`
# ----------------------------------------------------------------------------
# Same-origin deployment: point API at /api under the same host. If you split
# domains, update CORS (WEB_URL) and cookie domain accordingly.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://your-domain.kz/api
NEXT_PUBLIC_APP_URL=https://your-domain.kz
NEXT_PUBLIC_BOT_USERNAME=worktime_bot
NEXT_PUBLIC_DEFAULT_LOCALE=ru
NEXT_PUBLIC_DISPLAY_KEY=


# ----------------------------------------------------------------------------
# Office Display kiosk mode (optional)
# ----------------------------------------------------------------------------
DISPLAY_KEYS={}


# ----------------------------------------------------------------------------
# Google Sheets export
# ----------------------------------------------------------------------------
# In production, mount the service-account JSON as a docker secret and point
# this variable at the mount path (e.g. /run/secrets/google-service-account).
# ----------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_JSON=/app/service-account.json


# ----------------------------------------------------------------------------
# Email / SMTP - production provider
# ----------------------------------------------------------------------------
# Pick a provider with DKIM/SPF configured for your sending domain.
# Typical: Postmark (smtp.postmarkapp.com:587) or AWS SES.
# ----------------------------------------------------------------------------
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=<set in secret manager>
SMTP_PASS=<set in secret manager>
MAIL_FROM=noreply@your-domain.kz


# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
# Use a PRODUCTION Sentry project (not the same as dev) and set LOG_LEVEL
# to info or warn. Disable Swagger unless the API is private / VPN-only.
# ----------------------------------------------------------------------------
SENTRY_DSN=<set in secret manager>
NEXT_PUBLIC_SENTRY_DSN=<prod sentry browser dsn>
LOG_LEVEL=info
ENABLE_SWAGGER=false


# ----------------------------------------------------------------------------
# Billing (future) - leave blank until the billing module ships
# ----------------------------------------------------------------------------
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=


# ----------------------------------------------------------------------------
# Fonts (PDF rendering)
# ----------------------------------------------------------------------------
FONTS_PATH=/app/assets/fonts


# ----------------------------------------------------------------------------
# nginx / TLS (production-only)
# ----------------------------------------------------------------------------
# NGINX_HOST must match the certificate CN/SAN served by nginx.
# LETSENCRYPT_EMAIL receives expiry notices from Let's Encrypt; a real,
# monitored inbox is required (not an alias).
# ----------------------------------------------------------------------------

# [REQUIRED] Public hostname served by nginx.
NGINX_HOST=your-domain.kz

# [REQUIRED] Contact email for certbot / Let's Encrypt expiry notices.
LETSENCRYPT_EMAIL=info@aoneagency.kz


# ============================================================================
# Production deploy checklist
# ============================================================================
#   [ ] All <set in secret manager> placeholders replaced from vault
#   [ ] DATABASE_URL uses sslmode=require
#   [ ] REDIS_URL uses rediss:// or REDIS_PASSWORD is set + enforced
#   [ ] JWT/QR secrets are 64-byte hex and unique across environments
#   [ ] ENABLE_SWAGGER=false (unless API is private)
#   [ ] SENTRY_DSN points at the PROD Sentry project
#   [ ] SMTP credentials tested with a live send
#   [ ] NGINX_HOST resolves to the public IP with a valid TLS cert
#   [ ] A human monitors LETSENCRYPT_EMAIL for expiry warnings
# ============================================================================
