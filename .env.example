# ============================================================================
# Tact — Environment Variables
# ============================================================================
# Copy to .env for local dev:
#   cp .env.example .env
# For production:
#   cp .env.prod.example .env.prod
#
# This file documents every variable consumed by the backend (NestJS + Prisma),
# the frontend (Next.js), docker-compose, and the nginx reverse proxy.
#
# Legend:
#   [REQUIRED]  - the service will refuse to start without this value
#   [OPTIONAL]  - safe default or feature-flagged; may be empty
#   [SECRET]    - treat as a credential; never commit real values
#   [PUBLIC]    - embedded into the frontend bundle; visible to end users
# ============================================================================


# ----------------------------------------------------------------------------
# 1. Database (PostgreSQL)
# ----------------------------------------------------------------------------
# Primary system-of-record for users, shifts, companies, attendance logs, etc.
# Consumed by Prisma (backend) via DATABASE_URL and by the `postgres` service
# in docker-compose via the POSTGRES_* trio.
# Keep POSTGRES_USER/PASSWORD/DB in sync with DATABASE_URL or migrations will
# silently fail on fresh boots.
# ----------------------------------------------------------------------------

# [REQUIRED][SECRET] Full Postgres connection string used by Prisma.
# Format: postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=<disable|require>
# Notes:
#   - In production, append ?sslmode=require (managed Postgres enforces TLS).
#   - For high concurrency, point this at a PgBouncer pooler on port 6432 and
#     set ?pgbouncer=true&connection_limit=1 to play nicely with Prisma.
#   - Host must be "postgres" (not localhost) when running inside docker-compose.
DATABASE_URL=postgres://worktime:worktime@localhost:5432/worktime

# [REQUIRED] Database name created on first boot by the postgres container.
POSTGRES_DB=worktime

# [REQUIRED] Role that owns the database; used by both the app and migrations.
POSTGRES_USER=worktime

# [REQUIRED][SECRET] Password for POSTGRES_USER.
# Rotate in production; use `openssl rand -base64 32` for strong values.
POSTGRES_PASSWORD=worktime


# ----------------------------------------------------------------------------
# 2. Cache / Sessions (Redis)
# ----------------------------------------------------------------------------
# Used for: refresh-token revocation lists, rate-limit counters, BullMQ job
# queues (reminders, digest emails, webhook retries), and ephemeral QR nonces.
# If Redis is unavailable the backend still starts but queue-backed features
# (email, push, scheduled jobs) are disabled.
# ----------------------------------------------------------------------------

# [REQUIRED] Redis URL. Prefer rediss:// (TLS) in production.
# Format: redis[s]://[:PASSWORD@]HOST:PORT[/DB_INDEX]
REDIS_URL=redis://localhost:6379

# [OPTIONAL][SECRET] Password for Redis AUTH when not encoded in the URL.
# Leave blank in dev. In production, set a value AND uncomment `requirepass`
# in docker/redis/redis.conf.
REDIS_PASSWORD=


# ----------------------------------------------------------------------------
# 3. Auth / JWT / Crypto
# ----------------------------------------------------------------------------
# All secrets MUST be at least 32 random bytes (use `openssl rand -hex 64`).
# Rotating any of these invalidates existing sessions / QR codes.
# Never reuse the same value across two variables.
# ----------------------------------------------------------------------------

# [REQUIRED][SECRET] Signs short-lived access tokens (~15 min).
# Keep on backend only; never expose to the browser.
JWT_SECRET=

# [REQUIRED][SECRET] Signs long-lived refresh tokens (~30 days).
# MUST differ from JWT_SECRET so a leak of one does not imply the other.
JWT_REFRESH_SECRET=

# [REQUIRED][SECRET] HMAC key for signing office check-in QR payloads.
# Each QR is a time-boxed HMAC(employee_id, office_id, ts); rotating forces
# re-issuance of printed QRs.
QR_HMAC_SECRET=

# [OPTIONAL][SECRET] Shared verification key used by the Next.js middleware
# to validate access tokens on the edge without calling the backend.
# If unset, the middleware falls back to calling /auth/me on every nav.
# MUST match JWT_SECRET (symmetric) or the public half if you move to RS256.
JWT_PUBLIC_SECRET=


# ----------------------------------------------------------------------------
# 4. Telegram
# ----------------------------------------------------------------------------
# The primary login channel: users authenticate via a Telegram deep-link flow.
# Bot also delivers reminders, shift invites, and attendance summaries.
# Create a bot via @BotFather to obtain the token and username.
# ----------------------------------------------------------------------------

# [REQUIRED][SECRET] Bot API token from @BotFather.
# Format: "<bot_id>:<alphanum>"; never commit to git.
TELEGRAM_BOT_TOKEN=

# [REQUIRED] Bot username without the leading @.
# Used to build t.me/<username>?start=<payload> deep links.
TELEGRAM_BOT_USERNAME=worktime_dev_bot

# [OPTIONAL] Platform super-admin Telegram IDs (operators of WorkTime itself,
# not tenant owners). Comma-separated bigints with full cross-company
# visibility via /admin/* API routes. Leave empty to lock admin endpoints.
# Find your ID via @userinfobot.
SUPER_ADMIN_TELEGRAM_IDS=

# [OPTIONAL][SECRET] Secret token passed to Telegram setWebhook as
# `secret_token`; the backend rejects webhook calls without it.
# Recommended in production; generate with `openssl rand -hex 32`.
TELEGRAM_WEBHOOK_SECRET=


# ----------------------------------------------------------------------------
# 5. API / HTTP
# ----------------------------------------------------------------------------
# Public URLs used for CORS, cookie domains, and absolute link generation
# inside emails / Telegram messages. CORS on the backend is computed from
# WEB_URL: any origin not matching WEB_URL is rejected.
# ----------------------------------------------------------------------------

# [REQUIRED] TCP port the NestJS HTTP server listens on.
# In docker-compose this is exposed via the `api` service.
API_PORT=4000

# [REQUIRED] Public origin of the Next.js frontend.
# Drives CORS allowlist, refresh-cookie Domain attribute, and OAuth redirects.
# Must match the scheme+host a browser actually sees (mind http vs https).
WEB_URL=http://localhost:3000


# ----------------------------------------------------------------------------
# 6. Frontend (NEXT_PUBLIC_*)
# ----------------------------------------------------------------------------
# Any variable prefixed NEXT_PUBLIC_ is baked into the client bundle at build
# time and is therefore visible to every visitor. Never put secrets here.
# Values are read by Next.js at `next build`, so changing them requires a
# rebuild of the web image.
# ----------------------------------------------------------------------------

# [REQUIRED][PUBLIC] Base URL the browser uses to reach the API.
# In dev, this is the local NestJS port. In prod, same-origin via nginx is
# preferred (e.g. https://your-domain.kz/api).
NEXT_PUBLIC_API_URL=http://localhost:4000

# [REQUIRED][PUBLIC] Canonical URL of the web app itself.
# Used for absolute og:url meta tags and share links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [REQUIRED][PUBLIC] Bot username (without @) used to render
# t.me/<bot>?start=<payload> links in the login button.
# Typically equals TELEGRAM_BOT_USERNAME.
NEXT_PUBLIC_BOT_USERNAME=worktime_dev_bot

# [OPTIONAL][PUBLIC] Default locale before user overrides. Supported: ru, kk, en.
NEXT_PUBLIC_DEFAULT_LOCALE=ru

# [OPTIONAL][PUBLIC] Static key injected into /display screens so an office
# tablet can boot into kiosk mode without an interactive login. Pair with
# DISPLAY_KEYS below on the backend. Example: "office-almaty-01".
NEXT_PUBLIC_DISPLAY_KEY=


# ----------------------------------------------------------------------------
# 7. Office Display (kiosk mode)
# ----------------------------------------------------------------------------
# WorkTime exposes a /display page intended for a wall-mounted tablet showing
# the daily attendance board and QR for self check-in. Each physical display
# authenticates via a pre-shared key mapped to a specific office.
# ----------------------------------------------------------------------------

# [OPTIONAL][SECRET] JSON object mapping display-key -> { officeId, companyId }.
# The backend middleware matches NEXT_PUBLIC_DISPLAY_KEY against this map.
# Example (single-line, because dotenv does not support multi-line JSON):
#   DISPLAY_KEYS={"office-almaty-01":{"officeId":"ofc_01","companyId":"co_01"},"office-astana-02":{"officeId":"ofc_02","companyId":"co_01"}}
# Leave as {} to disable kiosk mode entirely.
DISPLAY_KEYS={}


# ----------------------------------------------------------------------------
# 8. Google Sheets export
# ----------------------------------------------------------------------------
# WorkTime can push daily/weekly attendance reports into a Google Sheet shared
# with a service account. Create a service account in Google Cloud Console,
# enable the Sheets API, download the JSON key, and share the target Sheet
# with the service account's client_email.
# ----------------------------------------------------------------------------

# [OPTIONAL][SECRET] Path to the service-account key file (recommended),
# OR a single-line JSON blob of the key itself. The backend auto-detects:
#   - if the value starts with "{" it is parsed as inline JSON;
#   - otherwise it is treated as a filesystem path and read at boot.
# In docker, mount the file read-only at /app/service-account.json.
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json


# ----------------------------------------------------------------------------
# 9. Email / SMTP
# ----------------------------------------------------------------------------
# Used for password-reset fallback, owner invitations, and weekly digests.
# In dev we default to MailHog (docker-compose.tools.yml) on host "mailhog"
# so you can browse sent mail at http://localhost:8025 without real delivery.
#
# Provider presets:
#   Postmark:  SMTP_HOST=smtp.postmarkapp.com  SMTP_PORT=587
#   SendGrid:  SMTP_HOST=smtp.sendgrid.net     SMTP_PORT=587  SMTP_USER=apikey
#   Mailgun:   SMTP_HOST=smtp.mailgun.org      SMTP_PORT=587
#   AWS SES:   SMTP_HOST=email-smtp.<region>.amazonaws.com SMTP_PORT=587
# ----------------------------------------------------------------------------

# [OPTIONAL] SMTP relay hostname.
SMTP_HOST=mailhog

# [OPTIONAL] SMTP port. Common values: 25 (plain), 587 (STARTTLS), 465 (TLS).
SMTP_PORT=1025

# [OPTIONAL][SECRET] SMTP username. Leave blank for MailHog / open relays.
SMTP_USER=

# [OPTIONAL][SECRET] SMTP password or API key.
SMTP_PASS=

# [OPTIONAL] From-address stamped on every outgoing email.
# Must be authorized by your provider (SPF/DKIM aligned).
MAIL_FROM=noreply@worktime.local


# ----------------------------------------------------------------------------
# 10. Observability
# ----------------------------------------------------------------------------
# Error tracking (Sentry) and log verbosity. Keep LOG_LEVEL=debug locally and
# info/warn in production to avoid noisy log bills.
# ----------------------------------------------------------------------------

# [OPTIONAL][SECRET] Sentry DSN for the backend.
# Empty value disables the Sentry transport entirely.
SENTRY_DSN=

# [OPTIONAL][PUBLIC] Sentry DSN for the browser bundle.
# Safe to expose (DSNs are designed to be public) but still tenant-scoped.
NEXT_PUBLIC_SENTRY_DSN=

# [OPTIONAL] Pino log level. One of: fatal, error, warn, info, debug, trace.
LOG_LEVEL=debug

# [OPTIONAL] If "true", mounts /docs with Swagger UI on the API.
# Disable in production unless the API is private.
ENABLE_SWAGGER=true


# ----------------------------------------------------------------------------
# 11. Rate limiting / Webhooks
# ----------------------------------------------------------------------------
# The global throttler uses Redis; no env var required. Webhook endpoints
# additionally validate a shared secret (see TELEGRAM_WEBHOOK_SECRET above).
# Add other provider webhook secrets here as the product grows.
# ----------------------------------------------------------------------------

# Placeholder: future webhook secrets go here, e.g. STRIPE_WEBHOOK_SECRET,
# YOOKASSA_WEBHOOK_SECRET, etc.


# ----------------------------------------------------------------------------
# 12. Billing (future — not yet wired up)
# ----------------------------------------------------------------------------
# WorkTime plans to integrate YooKassa for KZ/RU card payments. These
# variables are declared here so the shape of the .env does not drift when
# billing ships. Keep them commented until the billing module lands.
# ----------------------------------------------------------------------------

# [TODO][SECRET] YooKassa shop identifier from the merchant cabinet.
# YOOKASSA_SHOP_ID=

# [TODO][SECRET] YooKassa API secret key (live or test).
# Rotate immediately after any leak; keep test/live strictly separated.
# YOOKASSA_SECRET_KEY=


# ----------------------------------------------------------------------------
# 13. Tooling / Admin UIs (docker --profile tools)
# ----------------------------------------------------------------------------
# Only relevant when running `docker compose --profile tools up -d`.
# Exposes pgAdmin (http://localhost:5050) for DB inspection and MailHog
# (http://localhost:8025) for SMTP capture. Never expose these profiles in
# production -- they have no rate limiting or audit trail.
# ----------------------------------------------------------------------------

# [OPTIONAL] Initial admin login for pgAdmin.
PGADMIN_EMAIL=admin@worktime.local

# [OPTIONAL][SECRET] Initial admin password for pgAdmin.
PGADMIN_PASSWORD=admin


# ----------------------------------------------------------------------------
# 14. Fonts (PDF rendering)
# ----------------------------------------------------------------------------
# WorkTime renders PDF reports (attendance, payroll) with pdfkit. It loads
# Fraunces (display) and Inter (body) TTFs from disk. The Docker image bakes
# them in at /app/assets/fonts; locally you can point at the repo copy.
# ----------------------------------------------------------------------------

# [OPTIONAL] Directory holding Fraunces-*.ttf and Inter-*.ttf.
# Must NOT end with a trailing slash.
FONTS_PATH=./assets/fonts


# ============================================================================
# End of .env.example
# ============================================================================
# Checklist before first `docker compose up`:
#   [ ] DATABASE_URL / POSTGRES_* kept in sync
#   [ ] JWT_SECRET, JWT_REFRESH_SECRET, QR_HMAC_SECRET are random 64-byte hex
#   [ ] TELEGRAM_BOT_TOKEN + TELEGRAM_BOT_USERNAME set from @BotFather
#   [ ] At least one SUPER_ADMIN_TELEGRAM_IDS entry (your own TG id)
#   [ ] NEXT_PUBLIC_API_URL / NEXT_PUBLIC_APP_URL reflect the browser origin
# ============================================================================
